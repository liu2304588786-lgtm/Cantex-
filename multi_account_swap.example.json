      "instrument_id": "Amulet",
      "instrument_admin": "DSO::1220b1431ef217342db44d516bb9befde802be7d8899637d290895fa58880f19accc",
      "symbol": "CC"
    },
    "min_reference_ticket_size": "10",
    "sell_ratio_min": "0.30",
    "sell_ratio_max": "0.99",
    "min_sell_amount": "6",
    "max_network_fee": "0.2",
    "max_slippage": "0.005",
    "create_intent_account": true,
    "amount_precision": 10
  },
  "accounts": [
    {
      "name": "account-01",
      "operator_key_env": "CANTEX_OPERATOR_KEY",
      "trading_key_env": "CANTEX_TRADING_KEY",
      "proxy_url_env": "CANTEX_PROXY_ACCOUNT_01",
      "log_path": "logs/account-01.log"
    },
    {
